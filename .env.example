# ── Secrets (REQUIRED — app will not start without these) ─────────────
AUTH_SECRET_KEY=change-me-to-a-random-64-char-hex-string
DOWNLOAD_TOKEN_SECRET_KEY=change-me-to-a-different-random-64-char-hex-string

# ── Infrastructure ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgrespassword@db:5432/mycloud
REDIS_URL=redis://redis:6379/0

# ── CORS (comma-separated origins) ───────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Storage ───────────────────────────────────────────────────────────
MAX_STORAGE_BYTES=5368709120
CHUNK_SIZE_BYTES=5242880

# ── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_CAPACITY=10
RATE_LIMIT_REFILL_RATE=5

# ── Token Expiry ──────────────────────────────────────────────────────
DOWNLOAD_TOKEN_EXPIRE_MINUTES=60
AUTH_TOKEN_EXPIRE_MINUTES=1440
